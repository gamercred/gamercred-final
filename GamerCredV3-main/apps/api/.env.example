# =====================================================================
# STEAM CRED API — .env
# Copy to .env and fill in. NEVER commit .env.
# =====================================================================

# Set true to skip Steam API + Postgres and serve mock data.
# Great for previewing the UI before getting your Steam key / Supabase URL.
# When true, STEAM_API_KEY and DATABASE_URL are NOT required.
STUB_MODE=true

# Steam Web API key. Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=DA8077324CBA8AB91B6AB94E3A407787

# Supabase Postgres pooled connection string (port 6543, transaction pooler).
# Project Settings -> Database -> Connection string -> URI -> "Transaction pooler"
# Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.eecflpobazekowxfsjwl:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.eecflpobazekowxfsjwl:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Session signing secret. MUST be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Comma-separated allowlist of frontend origins. NO trailing slash, scheme included.
# In Codespaces, put your forwarded :5173 URL here:
#   https://<codespace-name>-5173.app.github.dev
# Multiple values: separate with commas.
CORS_ORIGINS=http://localhost:5173

# Canonical public base URL of THIS API. Optional but recommended for prod.
# If unset, the API trusts X-Forwarded-Proto/Host from the proxy.
# API_BASE_URL=

# Port the API listens on.
PORT=4000

# 'development' or 'production'.
NODE_ENV=development
