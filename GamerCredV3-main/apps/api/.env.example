# =====================================================================
# STEAM CRED API — .env.example
# Copy this to .env and fill in real values. NEVER commit .env.
#   cp apps/api/.env.example apps/api/.env
# =====================================================================

# Set true to skip Steam API + Postgres and serve mock data.
# Great for previewing the UI without credentials.
# When true, STEAM_API_KEY and DATABASE_URL are NOT required.
STUB_MODE=false

# Steam Web API key. Register at https://steamcommunity.com/dev/apikey
# Required unless STUB_MODE=true.
STEAM_API_KEY=

# Supabase Postgres pooled connection string (port 6543, transaction pooler).
# Project Settings -> Database -> Connection string -> URI -> "Transaction pooler"
# Replace [YOUR-PASSWORD] with your DB password.
# Required unless STUB_MODE=true.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432). Used for migrations.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Session signing secret. MUST be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Comma-separated allowlist of frontend origins. NO trailing slash, scheme included.
# Local dev: http://localhost:5173
# Codespaces: https://<codespace-name>-5173.app.github.dev
# Multiple values: separate with commas.
CORS_ORIGINS=http://localhost:5173

# Canonical public base URL of THIS API. Optional but recommended for prod.
# If unset, the API trusts X-Forwarded-Proto/Host from the proxy.
# API_BASE_URL=

# Port the API listens on.
PORT=4000

# 'development' or 'production'.
NODE_ENV=development
